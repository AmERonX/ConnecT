# Copy this file to .env and fill in your own values.
# .env is gitignored and must never be committed.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Access tokens are verified via Supabase JWKS endpoint (/auth/v1/.well-known/jwks.json)
# with a /auth/v1/user fallback. No JWT secret needed.

COHERE_API_KEY=your-cohere-api-key

# Supabase pooled connection (Transaction mode, port 5432)
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[db-password]@aws-1-[region].pooler.supabase.com:5432/postgres?sslmode=require

# Optional: separate service-role DB URL (defaults to SUPABASE_DB_URL if not set)
SUPABASE_SERVICE_DB_URL=postgresql://postgres.[project-ref]:[db-password]@aws-1-[region].pooler.supabase.com:5432/postgres?sslmode=require

API_PORT=8000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5500,http://localhost:3000
